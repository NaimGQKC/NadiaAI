# === NadiaAI Environment Variables ===
# Copy this to .env and fill in your values.
# NEVER commit .env to git.

# Google Sheets — see docs/SETUP_GOOGLE_SHEETS.md
GOOGLE_SERVICE_ACCOUNT_JSON=path/to/service-account.json
LEADS_SHEET_ID=your-google-sheet-id-here

# Email (Gmail with App Password — see docs/SETUP_GOOGLE_SHEETS.md §3)
SMTP_USER=your.email@gmail.com
SMTP_PASSWORD=your-app-password
MAMA_EMAIL=nadia@example.com

# Optional: developer alert email for pipeline failures
DEV_ALERT_EMAIL=

# Database path (default: nadia_ai.db in working directory)
# NADIA_DB_PATH=nadia_ai.db

# TTL for person data in days (default: 730 = 24 months)
# PERSON_TTL_DAYS=730

# Catastro cache duration in days (default: 30)
# CATASTRO_CACHE_DAYS=30
